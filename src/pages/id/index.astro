---
import "../../styles/global.css";
import Navbar from "@/containers/Navbar.vue";
import HomePage from "@/containers/HomePage.vue";
import About from "@/containers/About.vue";
import Services from "@/containers/Services.vue";
import Experience from "@/containers/Experience.vue";
import Projects from "@/containers/Projects.vue";
import CallToAction from "@/containers/CallToAction.vue";
import Footer from "@/containers/Footer.vue";
---

<!DOCTYPE html>
<html lang="id" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Devi Adi Nufriana — Software Engineer dengan keahlian dalam React dan Vue. Membangun solusi web yang cepat, dapat diskalakan, dan berkualitas tinggi." />
    <meta name="author" content="Devi Adi Nufriana" />
    <meta property="og:title" content="Devi Adi Nufriana — Software Engineer" />
    <meta property="og:description" content="Software Engineer dengan keahlian dalam React dan Vue. Membangun solusi web yang cepat, dapat diskalakan, dan berkualitas tinggi." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://deanufriana.github.io/id" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>Devi Adi Nufriana — Software Engineer</title>
    <script
      type="text/partytown"
      src="https://www.googletagmanager.com/gtag/js?id=G-5XH9HL1N8D"
    ></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-5XH9HL1N8D");
    </script>
    <script is:inline>
      // Prevent flash: apply theme before render
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="antialiased">
    <Navbar lang="id" client:load />
    <main>
      <HomePage lang="id" client:load />
      <About lang="id" />
      <Services lang="id" />
      <Experience lang="id" />
      <Projects lang="id" />
      <CallToAction lang="id" client:load />
    </main>
    <Footer lang="id" />
  </body>
</html>
