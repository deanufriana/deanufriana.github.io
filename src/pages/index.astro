---
import "../styles/global.css";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/containers/Navbar.vue";
import HomePage from "@/containers/HomePage.vue";
import About from "@/containers/About.vue";
import Services from "@/containers/Services.vue";
import Experience from "@/containers/Experience.vue";
import Projects from "@/containers/Projects.vue";
import CallToAction from "@/containers/CallToAction.vue";
import Footer from "@/containers/Footer.vue";
---

<BaseLayout
  title="Devi Adi Nufriana — Software Engineer"
  description="Software Engineer with expertise in React and Vue. Building fast, scalable, and high-quality web solutions."
  canonicalUrl="https://deanufriana.github.io/"
>
  <Navbar client:load />
  <main id="main-content">
    <HomePage client:load />
    <About client:visible />
    <Services client:visible />
    <Experience client:visible />
    <Projects client:visible />
    <CallToAction client:visible />
  </main>
  <Footer />
</BaseLayout>
